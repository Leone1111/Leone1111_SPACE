---
import TagList from "./TagList.astro";
import { categoryLabels, formatDate, getNoteUrl } from "../lib/content";
import type { Note } from "../lib/content";

interface Props {
  note: Note;
}

const { note } = Astro.props;
---

<article class="post-card">
  <div class="post-card__meta">
    <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
    <span>{categoryLabels[note.data.category]}</span>
  </div>
  <h3><a href={getNoteUrl(note)}>{note.data.title}</a></h3>
  <p>{note.data.summary}</p>
  <TagList tags={note.data.tags} />
</article>
