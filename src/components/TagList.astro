---
import { getTagUrl, normalizeTag } from "../lib/content";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="tag-list" aria-label="标签">
  {
    tags.map((tag) => (
      <li>
        <a class="tag" href={getTagUrl(tag)}>
          #{normalizeTag(tag)}
        </a>
      </li>
    ))
  }
</ul>
