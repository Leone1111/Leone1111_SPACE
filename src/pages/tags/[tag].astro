---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { normalizeTag, sortByDate } from "../../lib/content";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  const tags = new Set<string>();

  for (const note of notes) {
    for (const tag of note.data.tags) {
      tags.add(normalizeTag(tag));
    }
  }

  return [...tags].map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const normalizedTag = normalizeTag(tag ?? "");
const notes = sortByDate(
  (await getCollection("notes")).filter((note) =>
    note.data.tags.some((item) => normalizeTag(item) === normalizedTag),
  ),
);
---

<BaseLayout title={`标签：${normalizedTag}`} description={`包含 ${normalizedTag} 标签的文章。`}>
  <section class="page-header">
    <p class="eyebrow">Tag</p>
    <h1>#{normalizedTag}</h1>
    <p>共有 {notes.length} 篇文章包含这个标签。</p>
  </section>

  <div class="post-grid">
    {notes.map((note) => <PostCard note={note} />)}
  </div>
</BaseLayout>
