---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTagUrl, normalizeTag } from "../../lib/content";

const notes = await getCollection("notes");
const tagCounts = new Map<string, number>();

for (const note of notes) {
  for (const tag of note.data.tags) {
    const normalized = normalizeTag(tag);
    tagCounts.set(normalized, (tagCounts.get(normalized) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="标签" description="浏览所有文章标签。">
  <section class="page-header">
    <p class="eyebrow">Tags</p>
    <h1>标签</h1>
    <p>从关键词进入相关笔记，适合追踪主题、工具和长期问题。</p>
  </section>

  <div class="tag-cloud">
    {
      tags.map(([tag, count]) => (
        <a class="tag-cloud__item" href={getTagUrl(tag)}>
          #{tag}
          <span>{count}</span>
        </a>
      ))
    }
  </div>
</BaseLayout>
