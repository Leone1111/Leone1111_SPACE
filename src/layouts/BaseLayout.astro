---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = "Leone1111";
const { title, description = "莫向外求，个人纪录与思考的空间" } = Astro.props;
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const navItems = [
  { href: "/", label: "首页" },
  { href: "/ideas", label: "想法" },
  { href: "/books", label: "读书" },
  { href: "/projects", label: "项目" },
  { href: "/tools", label: "工具" },
  { href: "/research", label: "科研" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="主导航">
        {
          navItems.map((item) => (
            <a href={item.href} class:list={{ active: Astro.url.pathname === item.href }}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>用 Markdown 慢慢保存值得回看的材料。</p>
    </footer>
  </body>
</html>
