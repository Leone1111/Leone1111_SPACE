---
import BaseLayout from "./BaseLayout.astro";
import TagList from "../components/TagList.astro";
import { categoryLabels, formatDate } from "../lib/content";
import type { Note } from "../lib/content";

interface Props {
  post: Note;
}

const { post } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <article class="article-shell">
    <header class="article-header">
      <p class="eyebrow">{categoryLabels[post.data.category]}</p>
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span>{categoryLabels[post.data.category]}</span>
        <TagList tags={post.data.tags} />
      </div>
      <p class="article-summary">{post.data.summary}</p>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
